+# Flask Application
+FLASK_SECRET_KEY=generate-a-long-random-string-here
+FLASK_ENV=development
+
+# Database Settings
+# Ensure this directory is persistent in your production deployment
+DATABASE_DIR=./Database
+
+# OpenRouter Configuration
+OPEN_ROUTER_API_key=your_openrouter_api_key_here
+OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
+
+# Google OAuth
+GOOGLE_CLIENT_ID=your_google_client_id_here
+GOOGLE_CLIENT_SECRET=your_google_client_secret_here
+
+# ── Mock Services ─────────────────────────────────────────────────────────────
+# Set to true to bypass real credentials during development / CI.
+# MOCK_SERVICES=true is a shorthand that sets all three to true.
+# The granular flags override MOCK_SERVICES when set explicitly.
+
+# MOCK_SERVICES=false       # master toggle: set true to mock email + telegram + LLM
+# MOCK_EMAIL=false          # use MockEmailService instead of real SMTP/IMAP
+# MOCK_TELEGRAM=false       # use MockTelegramState instead of real Telethon
+# MOCK_LLM=false            # use MockAgent instead of OpenRouter (no API key needed)
+
+# Optional: System/Security
+# SECRET_AUD=your_secret_audio_keyword_here
